{
  "name": "unite",
  "version": "2.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "cp-oncogrid-min": "cp node_modules/@dkfz-unite/oncogrid/dist/oncogrid.min.js public/unite.oncogrid.min.js",
    "cp-oncogrid-debug": "cp node_modules/@dkfz-unite/oncogrid/dist/oncogrid-debug.js public/unite.oncogrid-debug.js",
    "copy-oncogrid": "npm run cp-oncogrid-min && npm run cp-oncogrid-debug",
    "dev": "npm run copy-oncogrid && vite",
    "build": "npm run copy-oncogrid && vite build",
    "preview": "npm run copy-oncogrid && vite preview"
  },
  "dependencies": {
    "@dkfz-unite/oncogrid": "^3.1.1",
    "@quasar/extras": "^1.16.17",
    "axios": "^1.8.1",
    "bitecs": "^0.4.0",
    "d3": "^7.9.0",
    "dayjs": "^1.11.13",
    "flat": "^6.0.1",
    "papaparse": "^5.4.1",
    "plotly.js-dist-min": "^3.0.1",
    "quasar": "^2.18.1",
    "vue": "^3.5.13",
    "vue-papa-parse": "^3.1.0",
    "vue-router": "^4.5.1",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@quasar/vite-plugin": "^1.9.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "sass": "^1.87.0",
    "vite": "^6.3.5"
  }
}
